        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "FishSceneOnFishGame"
                ]
            }
        },
        "focus": {
            "Node.Action.Succeeded": "开始钓鱼",
            "Node.Recognition.Failed": "判断不在钓鱼界面，尝试返回"
        },
        "on_error": [
            "FishSceneAnyEnterFishGame"
        ],
        "next": [
            "FishNewGaming",
            "[Anchor]FishNewRestart"
        ]
    },
    "FishNewGaming":{
        "desc":"进行钓鱼游戏",
        "action": "Custom",
