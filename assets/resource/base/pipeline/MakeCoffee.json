{
    "AutoMakeCoffee": {
        "action": "Custom",
        "custom_action": "auto_make_coffee",
        "custom_action_param": {
            "count": 1,
            "freq": 2
        }
    },
    "MakeCoffeeScrollToTop": {
        "action": "Scroll",
        "target": [
            120,
            400
        ],
        "dy": 3600
    },
    "MakeCoffeeStart": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1057,
                    648,
                    178,
                    44
                ],
                "expected": [
                    "开始营业",
                    "開始營業",
                    "(?i)Open\\s*Shop",
                    "営業開始",
                    "영업 개시"
                ],
                "threshold": 0.8
            }
        }
    },
    "MakeCoffeeTargetCoffeeMaster": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    89,
                    236,
                    73,
                    22
                ],
                "expected": [
                    "新品",
                    "新品",
                    "(?i)New\\s*Product",
                    "新作",
                    "신제품"
                ],
                "threshold": 0.8
            }
        }
    },
    "MakeCoffeeStar": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1204,
                    109,
                    29,
                    27
                ],
                "template": "auto_make_coffee/star.png",
                "threshold": 0.9
            }
        }
    },
    "MakeCoffeeClaim": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    681,
                    539,
                    187,
                    38
                ],
                "expected": [
                    "领取",
                    "領取",
                    "(?i)Claim",
                    "受け取る",
                    "수령"
                ]
            }
        }
    }
}
