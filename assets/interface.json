{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "异环小助手，由MAAFramework强力驱动！",
    "contact": "QQ群: 1103323319",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaNTE!",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "version": "0.0.1",
    "mirrorchyan_rid": "MaaNTE",
    "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "FramePool",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "PostMessageWithWindowPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "钓鱼任务",
            "entry": "FishEntrance",
            "option": [
                "钓鱼循环次数",
                "钓鱼数量",
                "自动卖鱼",
                "自动买鱼饵"
            ]
        },
        {
            "name": "领取一咖舍收益",
            "entry": "领取一咖舍收益"
        },
        {
            "name": "自动做咖啡",
            "entry": "AutoMakeCoffee",
            "option": [
                "循环次数"
            ]
        },
        {
            "name": "实时辅助",
            "entry": "RealTimeTaskMain",
            "option": [
                "RealTimeCheckInterval",
                "RealTimeAutoSkip",
                "RealTimeAutoTeleport"
            ]
        }
    ],
    "option": {
        "钓鱼循环次数": {
            "type": "input",
            "label": "最大循环次数",
            "description": "限制整个钓鱼循环最多执行多少次",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "循环次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishStart": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "钓鱼数量": {
            "type": "input",
            "label": "每次钓鱼数量",
            "description": "设置每次自动钓鱼的数量",
            "inputs": [
                {
                    "name": "count",
                    "label": "数量",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishGameStart": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                }
            }
        },
        "自动卖鱼": {
            "type": "switch",
            "label": "自动卖鱼",
            "description": "是否启用自动卖鱼功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "FishStart": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "自动买鱼饵": {
            "type": "switch",
            "label": "自动买鱼饵",
            "description": "是否启用自动买鱼饵功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "循环次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "循环次数",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoMakeCoffee": {
                    "custom_action_param": {
                        "count": "{循环次数}"
                    }
                }
            }
        },
        "RealTimeCheckInterval": {
            "type": "input",
            "label": "检测间隔 (ms)",
            "description": "两次检测之间的间隔，单位毫秒",
            "inputs": [
                {
                    "name": "interval",
                    "default": "500",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "RealTimeSleep": {
                    "post_delay": "{interval}"
                }
            }
        },
        "RealTimeAutoSkip": {
            "type": "switch",
            "label": "自动剧情",
            "description": "是否自动跳过剧情",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "RealTimeAutoSkipAll"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoSkipAll": {
            "type": "switch",
            "label": "自动跳过全部剧情",
            "description": "检测到跳过按钮时自动点击",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeSkipPlot": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleport": {
            "type": "switch",
            "label": "自动传送",
            "description": "检测到特定传送点时自动点击传送",
            "cases": [
                {
                    "name": "Yes",
                    "label": "开启",
                    "option": [
                        "RealTimeAutoTeleportWitte",
                        "RealTimeAutoTeleportPhone"
                    ]
                },
                {
                    "name": "No",
                    "label": "关闭",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "RealTimeAutoTeleportWitte": {
            "type": "switch",
            "label": "维特海默塔",
            "description": "是否检测维特海默塔的传送点",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportWitte": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportWitte": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "RealTimeAutoTeleportPhone": {
            "type": "switch",
            "label": "ReroRero电话亭",
            "description": "是否检测ReroRero电话亭的传送点",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": true
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeTeleportPhone": {
                            "enabled": false
                        },
                        "RealTimeConfirmTeleportPhone": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}